# env.production.example — exemplo sem valores sensíveis
# Substitua os valores reais no painel do Vercel ou usando `npx vercel env add`

# Build (client) - required for client login URL generation
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_OAUTH_SERVER_URL=
VITE_SUPABASE_ANON_KEY=

# Server (runtime)
OAUTH_SERVER_URL=
SUPABASE_ANON_KEY=
SUPABASE_URL=
DATABASE_URL=
JWT_SECRET=

# Optional (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
